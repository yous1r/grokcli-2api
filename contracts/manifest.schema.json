{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://grokcli-2api.local/contracts/manifest.schema.json",
  "title": "grokcli-2api compatibility manifest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "oracle",
    "routes",
    "authentication",
    "stream_invariants",
    "failover",
    "nondeterministic_fields"
  ],
  "properties": {
    "schema_version": {
      "const": 1
    },
    "oracle": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "implementation",
        "version"
      ],
      "properties": {
        "implementation": {
          "enum": [
            "go",
            "python"
          ]
        },
        "version": {
          "type": "string",
          "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"
        },
        "admin_routes": {
          "type": [
            "object",
            "string"
          ]
        },
        "data_safety": {
          "type": [
            "object",
            "string"
          ]
        },
        "readiness": {
          "type": [
            "object",
            "string"
          ]
        }
      }
    },
    "routes": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "method",
          "paths",
          "protocol"
        ],
        "properties": {
          "method": {
            "enum": [
              "GET",
              "POST",
              "PATCH",
              "DELETE"
            ]
          },
          "paths": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "pattern": "^/"
            }
          },
          "protocol": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "authentication": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "headers",
        "precedence"
      ],
      "properties": {
        "headers": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "precedence": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "stream_invariants": {
      "type": "object",
      "additionalProperties": {
        "type": "array",
        "items": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "failover": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "allowed",
        "forbidden"
      ],
      "properties": {
        "allowed": {
          "type": "string"
        },
        "forbidden": {
          "type": "string"
        }
      }
    },
    "nondeterministic_fields": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^\\$"
      }
    }
  }
}
